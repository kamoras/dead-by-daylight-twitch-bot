# =============================================================================
# Twitch Bot Credentials
# =============================================================================

# The Twitch username of your bot account.
# Create a dedicated account for the bot — it will join and chat in channels.
TWITCH_BOT_USERNAME=your_bot_username

# OAuth token for the bot account. Must be prefixed with "oauth:".
# Get one via the Twitch Developer Console (dev.twitch.tv/console).
# Required scopes: chat:read, chat:edit
TWITCH_BOT_TOKEN=oauth:your_token_here

# =============================================================================
# Bot Settings
# =============================================================================

# Command prefix (default: !)
BOT_PREFIX=!

# =============================================================================
# Queue Settings
# =============================================================================

# Controls whether players select a role when joining the queue.
#   off      - No roles. Viewers just type !join.
#   both     - Viewers specify !join survivor or !join killer.
#   survivor - Queue is survivor-only. Viewers just type !join.
#   killer   - Queue is killer-only. Viewers just type !join.
QUEUE_ROLES_MODE=both

# Maximum number of people allowed in the queue at once (default: 20).
QUEUE_MAX_SIZE=20

# =============================================================================
# Server / Database
# =============================================================================

# Port for the landing page and health check endpoint (default: 8080).
PORT=8080

# Path to the SQLite database file.
# Defaults to ./data/bot.db — change only if you need a custom location.
# DB_PATH=/app/data/bot.db
