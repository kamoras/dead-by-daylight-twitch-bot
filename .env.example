# =============================================================================
# Twitch Bot Credentials
# =============================================================================

# The Twitch username of your bot account.
# Create a dedicated account for the bot — it will join and chat in channels.
TWITCH_BOT_USERNAME=your_bot_username

# OAuth token for the bot account. Must be prefixed with "oauth:".
# Get one via the Twitch Developer Console (dev.twitch.tv/console).
# Required scopes: chat:read, chat:edit
TWITCH_BOT_TOKEN=oauth:your_token_here

# =============================================================================
# Bot Settings
# =============================================================================

# Command prefix — include a trailing space when using multi-word prefixes.
# Default is "!dbd " so users type commands like: !dbd join, !dbd queue
BOT_PREFIX=!dbd

# Message the bot posts when it enters a channel's chat, so the streamer knows
# it's present. Leave unset for the themed default.
# BOT_JOIN_MESSAGE=The fog rolls in — the queue bot has entered the trial. Type !dbd help for commands.

# =============================================================================
# Queue Settings
# =============================================================================

# Controls whether players select a role when joining the queue.
#   off      - No roles. Viewers just type !join.
#   both     - Viewers specify !join survivor or !join killer.
#   survivor - Queue is survivor-only. Viewers just type !join.
#   killer   - Queue is killer-only. Viewers just type !join.
QUEUE_ROLES_MODE=both

# Maximum number of people allowed in the queue at once (default: 20).
QUEUE_MAX_SIZE=20

# =============================================================================
# OBS Queue Overlay (optional)
# =============================================================================
# Each channel gets a transparent browser-source URL (copy it from the admin
# dashboard) showing the live queue. The URL token is derived from this secret;
# if unset it falls back to ADMIN_PASSWORD. Set it to keep overlay URLs stable
# even if you change the admin password.
# OVERLAY_SECRET=

# Twitch category the overlay is shown for. It hides whenever the streamer is
# playing anything else. Defaults to "Dead by Daylight".
# OVERLAY_GAME_NAME=Dead by Daylight

# =============================================================================
# Server / Database
# =============================================================================

# Port for the landing page and health check endpoint (default: 8080).
PORT=8080

# Path to the SQLite database file.
# Defaults to ./data/bot.db — change only if you need a custom location.
# DB_PATH=/app/data/bot.db

# Your domain name — used by Caddy to obtain a TLS certificate automatically.
# e.g. DOMAIN=bot.yourdomain.com
DOMAIN=

# =============================================================================
# Twitch — Live-Only Presence (optional)
# =============================================================================
# When configured, the bot only sits in a channel's chat while that channel is
# live, and closes/clears the queue when the stream ends.
#
#   TWITCH_CLIENT_ID     — from your Twitch Developer Console app registration
#   TWITCH_CLIENT_SECRET — from your Twitch Developer Console app registration
#
# With just the two above, presence is driven by polling Twitch for who's live
# (see STREAM_POLL_INTERVAL_MS below). Add the webhook secret + DOMAIN for
# instant join/leave via EventSub on top of polling:
#
#   TWITCH_WEBHOOK_SECRET — a random string you choose; used to verify that
#                           webhook deliveries actually come from Twitch.
#                           Generate one with: openssl rand -hex 20
#
# The webhook endpoint is automatically registered at:
#   https://YOUR_DOMAIN/webhook/twitch
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_WEBHOOK_SECRET=

# How often (ms) to reconcile chat presence with live status. Floored at 30000.
# STREAM_POLL_INTERVAL_MS=90000

# Password for the admin dashboard.
# Keep this secret — do not commit it. Set it as a GitHub Actions secret.
ADMIN_PASSWORD=

# Secret path segment for the admin URL.
# The admin dashboard will be at https://YOUR_DOMAIN/admin/YOUR_ADMIN_PATH
# Use a random string, e.g. the output of: openssl rand -hex 12
ADMIN_PATH=
